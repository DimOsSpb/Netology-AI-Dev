SERVICE_NAME = "XAssist"
# В данной конфигурации - секреты хранятся в закрытом каталоге ~/.secret в виде файлов со значением ключа
# Т.е. в .env в корне репозитория или в папке проекта вы прописываете:
# API_KEY = "~/.secret/api_key" например для OPENROUTER
API_KEY = "~/.secret/openrouter_api_key"
# Или прописываете сразу API_KEY = value.
API_KEY = "xxxxxxxxxxxxxxxxxxxxxxxxxx"
# Система поймет как интерпритировать значение
# Важно - для ключа в файле значение пути файла должно начинаться с ["~", "./", "/"]
# По аналогии для резервного провайдера
FALLBACK_API_KEY = "Ollama"
# --------------
BASE_URL="https://openrouter.ai/api/v1"
PRIMARY_MODEL="openai/gpt-oss-120b:free"

FALLBACK_BASE_URL="http://localhost:11434/v1"
FALLBACK_MODEL="qwen2:1.5b"

# Настройки STT модели faster_whisper 
STT_MODEL="small"
STT_DEVICE="cpu"
STT_CTYPE="int8"
# TTS
PIPER_BIN="infrastructure/tts/piper/bin/piper"
TTS_MODEL_PATH="infrastructure/tts/piper/models/ru_RU-irina-medium.onnx"

# Дополнительные настройки, имеют значения по умолчанию - см. config.py
#
# REQUEST_TIMEOUT_SECONDS
# RETRY_ATTEMPTS
# HISTORY_LIMIT
# LOG_PATH
# REDIS_HOST
# REDIS_PORT
# REDIS_TTL
